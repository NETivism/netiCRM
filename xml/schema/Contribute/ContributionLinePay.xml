  </field>
  <foreignKey>
    <name>contribution_recur_id</name>
    <table>civicrm_contribution_recur</table>
    <key>id</key>
    <add>4.0</add>
    <onDelete>SET NULL</onDelete>
  </foreignKey>
  <field>
